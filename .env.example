NODE_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=4000
WA_CONNECTOR_PORT=4010
POSTGRES_DB=omnichannel
POSTGRES_USER=omni_user
POSTGRES_PASSWORD=omni_pass
DATABASE_URL=postgresql://omni_user:omni_pass@postgres:5432/omnichannel?schema=public
REDIS_URL=redis://redis:6379
JWT_SECRET=change-this-super-secret-key-with-32-chars
JWT_EXPIRES_IN=15m
WA_SESSIONS_PATH=/var/lib/wa-sessions
UPLOADS_PATH=/app/uploads
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
INTERNAL_SERVICE_TOKEN=change-me-internal-token
BACKEND_INTERNAL_URL=http://backend:4000/api/internal
WA_CONNECTOR_INTERNAL_URL=http://wa-connector:4010/internal
